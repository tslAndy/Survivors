spriteAtlas ./Resources/SpriteAtlases/Entities/Goblin.spriteAtlas

##-----------------------IDLE---------------------##
group Idle

anim IdleUp 
frametime 200
repeat true
key idle_up_1
key idle_up_2
key idle_up_3
key idle_up_4
endkey

anim IdleDown 
frametime 200
repeat true
key idle_down_1
key idle_down_2
key idle_down_3
key idle_down_4
endkey

anim IdleLeft 
frametime 200
repeat true
key idle_left_1
key idle_left_2
key idle_left_3
key idle_left_4
endkey

anim IdleRight 
frametime 200
repeat true
key idle_right_1
key idle_right_2
key idle_right_3
key idle_right_4
endkey

endgroup 
